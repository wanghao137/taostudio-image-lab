{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "rewrites": [
    {
      "source": "/api-proxy/:path*",
      "destination": "/api/proxy/:path*"
    }
  ],
  "functions": {
    "api/proxy/[...path].js": {
      "maxDuration": 300
    }
  }
}
