{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "taostudio-image-lab",
  "compatibility_date": "2026-05-07",
  "routes": [
    {
      "pattern": "image.taostudioai.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
