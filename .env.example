# Same-origin OpenAI-compatible image API proxy.
# VITE_* values are read at frontend build time.
VITE_API_PROXY_AVAILABLE=false
VITE_API_PROXY_LOCKED=false
VITE_API_PROXY_PREFIX=/api-proxy
IMAGE_API_PROXY_TARGET=https://your-gateway.example.com/v1
IMAGE_API_PROXY_ALLOWED_HOSTS=your-gateway.example.com
# Set to true to let the proxy accept any public HTTPS OpenAI-compatible API target
# sent by the browser through x-taostudio-api-base-url. Local/private targets are
# still rejected; use local development for http://127.0.0.1 or localhost services.
IMAGE_API_PROXY_ALLOW_PUBLIC_TARGETS=false

# Optional local-only OpenAI-compatible image API smoke test settings.
# Never commit real keys.
IMAGE_API_BASE_URL=https://your-gateway.example.com/v1
IMAGE_API_KEY=
IMAGE_API_MODEL=gpt-image-2
IMAGE_API_TEST_API_MODE=images
IMAGE_API_TEST_SIZE=1024x1024
IMAGE_API_TEST_CODEX_CLI=true
IMAGE_API_TEST_MODERATION=auto
IMAGE_API_TEST_TIMEOUT_MS=600000
